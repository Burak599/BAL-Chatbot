# =============================================================
# BAL Chatbot — Ortam Değişkenleri
# Kullanım: cp .env.example .env  (sonra değerleri doldur)
# =============================================================

# ── Groq LLM (en az biri zorunlu) ─────────────────────────────

# Birincil API anahtarı
GROQ_API_KEY=

# Alternatif: virgülle ayrılmış birden fazla anahtar
# GROQ_API_KEYS=gsk_xxx,gsk_yyy

# Alternatif: numaralı slotlar (GROQ_API_KEY ile birlikte kullanılabilir)
# GROQ_API_KEY_1=
# GROQ_API_KEY_2=
# GROQ_API_KEY_3=
# GROQ_API_KEY_4=
# GROQ_API_KEY_5=

# Model zinciri (virgülle ayrılmış; boş bırakılırsa varsayılan 4 model kullanılır)
# GROQ_MODEL_CHAIN=llama-3.3-70b-versatile,meta-llama/llama-4-maverick-17b-128e-instruct,qwen/qwen3-32b,meta-llama/llama-4-scout-17b-16e-instruct

# ── Veritabanı ────────────────────────────────────────────────

# Neon PostgreSQL (önerilir). Yoksa veya bağlantı başarısızsa SQLite kullanılır.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# ── Flask / Oturum ──────────────────────────────────────────

# Oturum çerezi imzası (üret: python3 -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=

# ── Auth / Roller ───────────────────────────────────────────

# Admin rolü verilecek e-postalar (virgülle ayrılmış, küçük harf)
# ADMIN_EMAILS=admin@example.com

# Google OAuth client ID (auth endpoint'leri şu an devre dışı)
# GOOGLE_CLIENT_ID=

# ── HTTPS / Ortam ───────────────────────────────────────────

# HTTP isteklerini HTTPS'e yönlendir (HF Space'te genelde gerekmez)
# FORCE_HTTPS=false

# Yerel geliştirmede HTTPS ile çalıştırma
# LOCAL_HTTPS=false

# Sunucu portu (HF Space otomatik atar; yerelde varsayılan 7860)
# PORT=7860

# ── Hugging Face deploy (yalnızca GitHub Actions) ───────────

# main → Space otomatik yükleme için GitHub Actions secret
# HF_TOKEN=
